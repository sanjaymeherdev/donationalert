{
  "buildCommand": "sed -i \"s|{{DEFAULT_YOUTUBE_URL}}|$DEFAULT_YOUTUBE_URL|g\" index.html && sed -i \"s|{{SE_CHAT_URL}}|$SE_CHAT_URL|g\" index.html",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/thankyou", "destination": "/thankyou.html" }
  ],
  "env": {
    "PRODUCTION_MODE": "true"
  }
}
